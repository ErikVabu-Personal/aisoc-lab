# aisoc.config.example — single-file configuration for the AISOC demo
# ─────────────────────────────────────────────────────────────────────
#
# 1. Copy this file to `aisoc.config` (gitignored) at the repo root.
# 2. Uncomment + fill in the values you want to override.
# 3. Run ./aisoc_demo.sh deploy — the script sources this file before
#    parsing CLI flags, so:
#      - aisoc.config            sets the baseline
#      - --flag=value on CLI     overrides aisoc.config for that run
#      - pre-set env in shell    overrides everything
#
# This is bash-`source`d, so use shell syntax (no quotes needed for
# simple values; quote anything containing spaces, JSON, or special
# characters).
#
# Most values map to Terraform variables via the TF_VAR_<name> contract
# Terraform supports natively. A few are deploy-script-level (no
# TF_VAR_ prefix). Both kinds are listed below.

# ── Azure subscription / resource group / region ────────────────────
# Resource group Phase 1 will create (if it doesn't exist) and Phases
# 2 + 3 will deploy into.
# TF_VAR_resource_group_name="rg-aisoc-demo"

# Region for Phase 1 (Sentinel + lab VM).
# TF_VAR_azure_location="westus"

# Region for Phase 2 (Function Apps). EP-series quota is most readily
# available in westcentralus on freshly-onboarded subscriptions.
# TF_VAR_location_override="westcentralus"

# Region for Foundry. Model Router + gpt-4.1-mini are gated to
# eastus2 / swedencentral.
# TF_VAR_foundry_location="eastus2"

# Override the active Azure subscription before any deploy step runs
# (defaults to whatever `az account show` returns).
# AZURE_SUBSCRIPTION_OVERRIDE="6e961575-c100-444e-a868-1972223b2410"

# ── Lab VM ──────────────────────────────────────────────────────────
# Lab VM admin password. If left unset, Phase 1 generates a random
# 28-char password (held in Terraform state, stable across re-applies)
# and the deploy script prints it at the end. Set explicitly here if
# you need a specific password.
# TF_VAR_admin_password="<your-vm-password>"

# Override the default admin username.
# TF_VAR_admin_username="azureadmin"

# VM size. Default is Standard_D2s_v3.
# TF_VAR_vm_size="Standard_D2s_v3"

# ── Foundry model deployment ────────────────────────────────────────
# Model identity. Defaults match the validated demo combo.
# TF_VAR_foundry_model_choice="gpt-4.1-mini"
# TF_VAR_foundry_model_version="2025-04-14"
# TF_VAR_foundry_model_deployment_name="gpt-4.1-mini"

# SKU + capacity. Capacity is in **thousands of TPM** for the
# GlobalStandard SKU — 1500 = 1,500,000 TPM.
# TF_VAR_foundry_model_sku_name="GlobalStandard"
# TF_VAR_foundry_model_sku_capacity="1500"

# ── Demo login roster (PixelAgents Web) ─────────────────────────────
# JSON object: {email: {password, roles}}. Wired into the Container
# App as a secret (encrypted at rest), exposed to the server as
# AISOC_USERS_JSON. Adding/removing users + reassigning roles is a
# one-line edit to this file + `terraform apply` in Phase 3.
#
# Known role slugs:
#   - "soc-manager"        → /config + user mgmt + approves
#                            knowledge-preamble + agent-instructions
#                            changes
#   - "detection-engineer" → approves detection-rule changes
#   - "soc-analyst"        → picks up incidents + answers HITL asks
#                            from triage / investigator / reporter
#
# A user can hold multiple roles. The SOC manager typically holds all
# three for full visibility during the demo.
#
# Demo-grade only: passwords are stored verbatim. Don't reuse real
# credentials here.
#
# Pure single-line JSON keeps the bash escaping simple — no nested
# quotes inside the string.
#
# Mirrors the hardcoded fallback in pixelagents_web/app/server.py
# (_load_users) so a fresh deploy with this uncommented gets the
# same roster as the no-config-file boot path.
# TF_VAR_pixelagents_users='{"erik.vanbuggenhout@nviso.eu":{"password":"admin123","roles":["soc-manager","detection-engineer","soc-analyst"]},"jeroen.laureys@nviso.eu":{"password":"saleswarmachine","roles":["soc-analyst"]},"arne.magnus@nviso.eu":{"password":"sales123","roles":["soc-manager","detection-engineer","soc-analyst"]},"julian.obenlandrecker@nviso.eu":{"password":"sales123","roles":["soc-manager","detection-engineer","soc-analyst"]},"maxim.deweerdt@nviso.eu":{"password":"needsmorecowbell","roles":["soc-manager","detection-engineer","soc-analyst"]},"jeroen.vandeleur@nviso.eu":{"password":"hardcorevibes","roles":["soc-manager","detection-engineer","soc-analyst"]},"daan.raman@nviso.eu":{"password":"ClasseAffaires","roles":["soc-manager","detection-engineer","soc-analyst"]},"kurt.ceuppens@nviso.eu":{"password":"iamtheboss","roles":["soc-manager","detection-engineer","soc-analyst"]},"jan.deblauwe@nviso.eu":{"password":"ebitda","roles":["soc-manager","detection-engineer","soc-analyst"]}}'
#
# Legacy shape (no roles) is still accepted — those users get zero
# roles and won't be able to hit /config or approve changes:
# TF_VAR_pixelagents_users='{"erik.vanbuggenhout@nviso.eu":"admin123"}'

# ── Additional Foundry model deployments (optional) ────────────────
# Extra deployments alongside the primary one — selectable per-agent
# in /config's model dropdown. Defaults to gpt-4.1 + gpt-4o-mini so
# the dropdown isn't a single-item list out of the box. Set to []
# to keep only the primary.
#
# JSON-encoded list of objects; field names match the Terraform
# variable schema (deployment_name, model_name, model_version,
# sku_name?, sku_capacity?, label?, description?).
# TF_VAR_foundry_additional_model_deployments='[{"deployment_name":"gpt-4.1","model_name":"gpt-4.1","model_version":"2025-04-14","label":"GPT-4.1","description":"Larger, more capable; better for tricky investigations."},{"deployment_name":"gpt-4o-mini","model_name":"gpt-4o-mini","model_version":"2024-07-18","label":"GPT-4o-mini","description":"Fast + cheap; good fit for triage."}]'

# ── Detection rule library (Foundry IQ knowledge base) ─────────────
# When enabled, Phase 2 stands up an Azure Storage account, an Azure
# AI Search service, and a Foundry IQ knowledge base over the
# container. The Detection Engineer agent gets an MCP tool that
# consults the KB before proposing new analytic rules. Defaults to
# enabled (Basic SKU); flip to false to skip the whole subsystem.
# TF_VAR_detection_rules_kb_enabled="true"
#
# Search SKU. Basic ≈ €80/mo and supports agentic retrieval at full
# quality. Free is 50MB/3 indexes (POC only). Standard / standard2 /
# standard3 add capacity + replicas — overkill for a demo.
# TF_VAR_detection_rules_kb_search_sku="basic"

# ── Threat Intel agent — Bing grounding (optional) ─────────────────
# When set, the deploy script attaches a Foundry bing_grounding tool
# to the Threat Intel agent so it can do live web research. The
# value is the NAME of a project connection (RemoteTool / API key)
# you've already created in Foundry pointing at a Bing Search v7
# resource. Leave unset to deploy the agent without web access — it
# will tell users so when asked.
#
# To create the connection once:
#   az cognitiveservices account project connection create \
#     -g "$RG" -n "$HUB" --project-name "$PROJ" \
#     --connection-name "bing-grounding" \
#     --target "https://api.bing.microsoft.com/" \
#     --auth-type ApiKey --api-key "<your bing search v7 key>" \
#     --category ApiKey
# Then:
# AISOC_BING_GROUNDING_CONNECTION="bing-grounding"

# ── Tavily web search (optional but strongly recommended) ───────────
# When set, the runner exposes a `web_search` tool to the Threat Intel
# and Investigator agents. They use it for live internet research
# (CVEs, IOCs, fresh threat-actor activity) without needing Foundry's
# bing_grounding tool to be wired. Sign up at https://tavily.com — the
# free tier covers 1000 searches/month and signup is one form.
# Independent of bing_grounding: both can be wired at the same time;
# the agent will use whichever is available.
# TF_VAR_tavily_api_key="tvly-..."

# ── OpenRouter (optional) ───────────────────────────────────────────
# Only needed if you've wired the gateway to call OpenRouter as well
# as Foundry — leave commented for the standard demo.
# TF_VAR_openrouter_api_key="sk-or-v1-..."

# ── Deploy-script-level options ─────────────────────────────────────
# Skip the OIDC bootstrap step on subsequent runs (the one-time SP +
# federated-credential setup). Useful in CI loops where the trust is
# already configured.
# AISOC_SKIP_OIDC=1

# GitHub repo to sync repo-vars into. Defaults to ErikVabu-Personal/
# aisoc-lab; override here if you fork.
# AISOC_GITHUB_REPO="<owner>/<repo>"
