# PixelAgents Web (Phase 3) — example tfvars
#
# Copy to terraform.tfvars and edit as needed:
#   cp terraform.tfvars.example terraform.tfvars

# RG + Azure region are inherited directly from Phase 1 — no override
# variables needed. If you want PixelAgents Web in a different RG /
# region than the rest of the stack, reintroduce them in variables.tf
# and wrap the consumers in coalesce().

# Optional: reuse a pre-existing Container Apps Environment.
# Leave unset to reuse Phase 1's env when available, or create a new
# one if Phase 1 didn't expose one.
# container_app_environment_id = "/subscriptions/.../managedEnvironments/cae-..."

# Container image tag. Deploy by SHA for reliable updates (see README Phase 4.3).
# image = "ghcr.io/erikvabu-personal/aisoc-lab-pixelagents-web:<GITHUB_SHA>"

# The Foundry project endpoint used by the ad-hoc chat endpoint is inherited
# automatically from Phase 2's `foundry_project_endpoint` output — no manual
# configuration needed.

# Demo login roster. Map of email -> password. Adding/removing users is
# now a one-line tfvars change — no source-code edit required. Wired
# into the Container App as a secret (encrypted at rest in ACA) and
# exposed to the server as AISOC_USERS_JSON.
#
# Demo-grade only — passwords are stored verbatim. For anything closer
# to production, hash them and gate logins on a real identity provider.
#
# Leave commented / empty {} to fall back to the server's hardcoded
# bootstrap roster (useful for first deploy).
#
# pixelagents_users = {
#   "alice@example.com" = "<password>"
#   "bob@example.com"   = "<password>"
# }
