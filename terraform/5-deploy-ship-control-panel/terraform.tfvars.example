# Rename to terraform.tfvars

resource_group = "rg-sentinel-test"
location       = "westus"

# Optional: reuse an existing Container Apps Environment ID (recommended if you already have one)
# container_app_environment_id = "/subscriptions/.../resourceGroups/.../providers/Microsoft.App/managedEnvironments/..."
container_app_environment_id = ""

create_log_analytics = true

app_name = "ca-ship-control-panel"

# Recommended: deploy by commit SHA tag for deterministic demos
image = "ghcr.io/erikvabu-personal/aisoc-ship-control-panel:latest"

ingress_port = 3000
