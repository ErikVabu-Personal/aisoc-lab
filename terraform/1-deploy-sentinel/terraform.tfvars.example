# Rename to terraform.tfvars and fill in values

# Region
location = "westus" # West US

# Disable auto-pick (it can be slow because it probes multiple regions/SKUs)
auto_select_location_and_sku = false

# (Optional) If you re-enable auto-pick later:
# location_candidates = ["westus"]
# vm_size_candidates  = ["Standard_B1ms", "Standard_B2s", "Standard_D2as_v5"]

# Windows VM credentials
# admin_username = "azureadmin"

# RDP allow-listing
# auto_detect_rdp_cidr = true
# allowed_rdp_cidr = "x.x.x.x/32"

# OpenRouter (optional)
# openrouter_api_key = "sk-or-v1-..."
resource_group_name = "rg-sentinel-test"
workspace_name      = "law-sentinel-test"
vm_name             = "win11-test"
vm_size             = "Standard_D2s_v3"

# Set to your public IP with /32
allowed_rdp_cidr = "203.0.113.10/32"

# Choose a strong password
admin_username = "azureadmin"
admin_password = "CHANGEME-StrongPassword-123!"

# Enable log collection via Azure Monitor Agent
enable_ama               = true
enable_windows_event_logs = true

# Defender for Endpoint onboarding (optional)
# This uses Key Vault to avoid copy/paste into tfvars.
# Steps:
# 1) terraform apply with enable_defender_for_endpoint=true
# 2) Provide the onboarding script.
#    Option A (recommended): upload it with az CLI:
#      az keyvault secret set --vault-name <vaultName> --name MDE-ONBOARD --file onboarding.cmd
#    Option B (LAB ONLY): let Terraform upload it (will be stored in TF state):
#      mde_onboarding_script_path = "./onboarding.cmd"
# 3) terraform apply again

enable_defender_for_endpoint  = false
mde_onboarding_secret_name    = "MDE-ONBOARD"
# mde_onboarding_script_path  = "./onboarding.cmd"

enable_sentinel_mde_connector = false

# Optional: auto shutdown time (HHMM) or null
auto_shutdown_time     = "1900"
auto_shutdown_timezone = "Romance Standard Time"
