# Rename to terraform.tfvars

# Defaults that work in many restricted subscriptions:
# - Keep Sentinel/VM in West US (Phase 1)
# - Deploy App Service/Function in West Central US where EP1 quota is often available

location_override = "westcentralus"
function_plan_sku = "EP1"


# Optional
# openrouter_api_key = "sk-or-v1-..."

# --- Foundry (Hub/Project + agent runtime config)
# These are REQUIRED for the Foundry Hub/Project Terraform (AzAPI) resources.
# The agent + model deployment is still done via script using Terraform outputs.

# OPTIONAL: if omitted, Terraform auto-generates unique-ish names using the random suffix.
# foundry_hub_name     = "aisoc-hub-<something-unique>"
# foundry_project_name = "aisoc-project"

# OPTIONAL: defaults to location_override/effective location
# Recommended: set Foundry location explicitly, separately from App Service quota hacks.
foundry_location = "westus"

# IMPORTANT:
# Creating Foundry projects via Terraform/AzAPI can take a very long time and may time out.
# Recommended: keep this false and run scripts/deploy_foundry_project.py after `terraform apply`.
foundry_manage_project_in_terraform = true

# Runner (Azure Container Apps)
# REQUIRED: runner container image (publish via GitHub Actions)
# Example:
# runner_image = "ghcr.io/erikvabu-personal/aisoc-runner:<sha>"
runner_image = "ghcr.io/erikvabu-personal/aisoc-runner:latest"

# REQUIRED: model choice + version + deployment name that agents should target
# Example:
# foundry_model_choice   = "gpt-4.1-mini"
# foundry_model_version  = "2026-03-17"
# foundry_model_deployment_name = "gpt-4.1-mini"
foundry_model_choice          = "gpt-4.1-mini"
foundry_model_version         = "2025-04-14"
foundry_model_deployment_name = "gpt-4.1-mini"

# If you hit: "SKU 'Standard' ... not supported", try:
foundry_model_sku_name     = "GlobalStandard"
foundry_model_sku_capacity = 1
