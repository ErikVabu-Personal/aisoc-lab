# Rename to terraform.tfvars

# Defaults that work in many restricted subscriptions:
# - Keep Sentinel/VM in West US (Phase 1)
# - Deploy App Service/Function in West Central US where EP1 quota is often available

location_override = "westcentralus"
function_plan_sku = "EP1"


# Optional
# openrouter_api_key = "sk-or-v1-..."

# --- Foundry (Hub/Project + agent runtime config)
# These are REQUIRED for the Foundry Hub/Project Terraform (AzAPI) resources.
# The agent + model deployment is still done via script using Terraform outputs.

# REQUIRED: pick a globally-unique hub/account name (Cognitive Services account)
foundry_hub_name = "aisoc-hub-CHANGE-ME"

# REQUIRED: project name (scoped under the hub/account)
foundry_project_name = "aisoc-project"

# OPTIONAL: defaults to location_override/effective location
# foundry_location = "westeurope"

# REQUIRED: model choice + deployment name that agents should target
foundry_model_choice          = "gpt-4.1-mini"
foundry_model_deployment_name = "gpt-4.1-mini"
