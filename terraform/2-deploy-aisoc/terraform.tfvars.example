# Rename to terraform.tfvars

# Defaults that work in many restricted subscriptions:
# - Keep Sentinel/VM in West US (Phase 1)
# - Deploy App Service/Function in West Central US where EP1 quota is often available

location_override = "westcentralus"
function_plan_sku = "EP1"


# Optional
# openrouter_api_key = "sk-or-v1-..."

# --- Foundry (Hub/Project + agent runtime config)
# These are REQUIRED for the Foundry Hub/Project Terraform (AzAPI) resources.
# The agent + model deployment is still done via script using Terraform outputs.

# OPTIONAL: if omitted, Terraform auto-generates unique-ish names using the random suffix.
# foundry_hub_name     = "aisoc-hub-<something-unique>"
# foundry_project_name = "aisoc-project"

# OPTIONAL: defaults to location_override/effective location
# Recommended: set Foundry location explicitly, separately from App Service quota hacks.
# NOTE: Model Router is region-gated; East US 2 and Sweden Central are known-supported regions.
foundry_location = "eastus2"

# IMPORTANT:
# Creating Foundry projects via Terraform/AzAPI can take a very long time and may time out.
# Recommended: keep this false and run scripts/deploy_foundry_project.py after `terraform apply`.

# Runner (Azure Container Apps)
# REQUIRED: runner container image (publish via GitHub Actions)
# Example:
# runner_image = "ghcr.io/erikvabu-personal/aisoc-runner:<sha>"
runner_image = "ghcr.io/erikvabu-personal/aisoc-runner:latest"

# REQUIRED: model choice + version + deployment name that agents should target
#
# Recommended default: gpt-4.1-mini (agent-runtime compatible)
#
# Example:
# foundry_model_choice          = "gpt-4.1-mini"
# foundry_model_version         = "2025-04-14"
# foundry_model_deployment_name = "gpt-4.1-mini"
foundry_model_choice          = "gpt-4.1-mini"
foundry_model_version         = "2025-04-14"
foundry_model_deployment_name = "gpt-4.1-mini"

# If you hit: "SKU 'Standard' ... not supported", try:
foundry_model_sku_name     = "GlobalStandard"
foundry_model_sku_capacity = 10

# Additional Foundry model deployments. Each entry creates one extra
# deployment in the Foundry account; the /config UI lets the SOC
# manager re-bind any agent to any of these via the per-agent model
# dropdown. Defaults to gpt-4.1 + gpt-4o-mini so a fresh deploy has
# options out of the box. Set to [] to keep only the primary deployment.
#
# foundry_additional_model_deployments = [
#   {
#     deployment_name = "gpt-4.1"
#     model_name      = "gpt-4.1"
#     model_version   = "2025-04-14"
#     label           = "GPT-4.1"
#     description     = "Larger, more capable; better for tricky investigations."
#   },
#   {
#     deployment_name = "gpt-4o-mini"
#     model_name      = "gpt-4o-mini"
#     model_version   = "2024-07-18"
#     label           = "GPT-4o-mini"
#     description     = "Fast + cheap; good fit for triage."
#   },
# ]

# ─────────────────────────────────────────────────────────────────────
# Detection rule library (Foundry IQ knowledge base)
# ─────────────────────────────────────────────────────────────────────
# Stands up an Azure Storage account + container, an Azure AI Search
# service, a Foundry IQ knowledge base over the container, and a
# project connection that exposes the KB to the Detection Engineer
# agent over MCP. The agent consults the library before proposing
# new analytic rules so it surfaces similar existing rules and
# avoids duplicates.
#
# After `terraform apply`, upload your rule files into the
# detection-rules container of the new storage account:
#
#   STORAGE=$(terraform output -raw detection_rules_storage_account)
#   az storage blob upload-batch \
#     --account-name "$STORAGE" \
#     --destination detection-rules \
#     --source ./my-rule-library \
#     --auth-mode login
#
# The indexer auto-runs every 30 minutes; trigger a one-shot pull
# with:
#
#   SEARCH=$(terraform output -raw detection_rules_search_endpoint)
#   ADMIN_KEY=$(az search admin-key show \
#     --resource-group <rg> --service-name <search-service> \
#     --query primaryKey -o tsv)
#   curl -X POST \
#     "${SEARCH}/indexers/detection-rules-indexer/run?api-version=2025-08-01-preview" \
#     -H "api-key: ${ADMIN_KEY}"
#
# Sigma .yml, .kql, .md, .txt, and .json are indexed by default.
#
# detection_rules_kb_enabled    = true    # set to false to skip the whole subsystem
# detection_rules_kb_search_sku = "basic" # free | basic | standard | standard2 | standard3
