{
  "IsEncrypted": false,
  "Values": {
    "AzureWebJobsStorage": "UseDevelopmentStorage=true",
    "FUNCTIONS_WORKER_RUNTIME": "python",

    "AZURE_AI_FOUNDRY_PROJECT_ENDPOINT": "https://<your-project>.services.ai.azure.com/api/projects/<project>" ,
    "AZURE_AI_MODEL_DEPLOYMENT": "model-router",

    "RUNNER_URL": "https://<runner>",
    "KEYVAULT_URI": "https://<kv>.vault.azure.net/",

    "AISOC_RUNNER_BEARER_SECRET_NAME": "AISOC-RUNNER-BEARER",

    "AISOC_CONFIDENCE_THRESHOLD": "50"
  }
}
